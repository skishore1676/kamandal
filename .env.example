# LLM (idea extraction, strategy mining)
# provider: openai | openrouter
VOL_CRUSH_LLM_PROVIDER=openrouter
VOL_CRUSH_LLM_API_KEY=your-openrouter-or-openai-key
# For OpenRouter, prefix the model (e.g. anthropic/claude-sonnet-4.5).
# For OpenAI, use a bare model name (e.g. gpt-4o).
VOL_CRUSH_LLM_MODEL=anthropic/claude-sonnet-4.5
# Backup model — used automatically if the primary model errors
# (rate limit, 5xx, model-not-found). Leave empty to disable fallback.
VOL_CRUSH_LLM_MODEL_BACKUP=anthropic/claude-haiku-4.5
# Optional: override base_url. OpenRouter auto-set when provider=openrouter.
# VOL_CRUSH_LLM_BASE_URL=

# OpenAI — required only for Whisper audio transcription (idea_scraper live/record).
# VOL_CRUSH_OPENAI_API_KEY=sk-...

# Groq — optional audio fallback for YouTube videos without captions.
# Off unless idea_sources.transcripts.providers entry for groq_whisper is enabled.
# GROQ_API_KEY=gsk_...

# Public broker
PUBLIC_SECRET_TOKEN=your-public-secret-token
PUBLIC_API_BASE_URL=https://api.public.com
PUBLIC_AUTH_ENDPOINT=https://api.public.com/userapiauthservice/personal/access-tokens
PUBLIC_ACCOUNT_ID=
PUBLIC_SESSION_FILE=data/cache/public_session.json
PUBLIC_ACCOUNT_CACHE_FILE=data/cache/public_account.json
API_REQUESTS_PER_SECOND=5.0
API_BURST_LIMIT=5
